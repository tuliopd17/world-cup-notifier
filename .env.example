# Copie para .env e preencha. O .env NÃO vai pro git.

# Token da football-data.org
FOOTBALL_DATA_TOKEN=coloque_seu_token_aqui

# Número de destino (o mesmo registrado no WhatsApp, com DDI)
WHATSAPP_PHONE=+553584242252

# Transporte via servidor próprio (Baileys). Com isto definido, o
# copa_zap.py manda a mensagem completa de uma vez para o wa-server.
WA_SERVER_URL=http://127.0.0.1:3000/send

# Senha simples compartilhada entre copa_zap.py e wa-server (defina um
# valor qualquer; protege o endpoint local). Deve ser igual nos dois.
WA_SERVER_TOKEN=troque_por_um_segredo

# --- Opcional: fallback CallMeBot (só usado se WA_SERVER_URL ficar vazio) ---
# CALLMEBOT_APIKEY=8461132
